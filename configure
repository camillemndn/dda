#!/bin/sh
# Detect the host's Rust target triple and substitute into src/Makevars.in.
set -e

if ! command -v cargo >/dev/null 2>&1; then
    echo "ERROR: cargo (Rust) is required but not on PATH." >&2
    echo "Install rustup from https://rustup.rs/ and ensure cargo is available." >&2
    exit 1
fi

TARGET="$(rustc -vV | awk '/host:/ { print $2 }')"
if [ -z "$TARGET" ]; then
    echo "ERROR: could not determine rustc host target." >&2
    exit 1
fi

sed "s|@TARGET@|${TARGET}|g" src/Makevars.in > src/Makevars
echo "Configured for TARGET=${TARGET}"
